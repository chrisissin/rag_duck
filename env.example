# Slack (Bot token + signing secret)
SLACK_BOT_TOKEN=....-......
SLACK_SIGNING_SECRET=..........
PORT=3000
# For org-level tokens (Enterprise Grid): set workspace ID if auth.test doesn't return team_id
# SLACK_TEAM_ID=T01234567

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/slack_rag

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1

# RAG
TOP_K=8
MAX_CONTEXT_CHARS=12000

# Indexer
SYNC_INTERVAL_SECONDS=300
HISTORY_PAGE_LIMIT=200
MAX_MESSAGES_PER_WINDOW=20
MAX_WINDOW_MINUTES=10
MAX_EMBEDDING_LENGTH=10000

ENABLE_MCP=true
DISABLE_SCALING_INTENT_DETECTION=false
DISABLE_ADD_MEMORY_DETECTION=false
DISABLE_APPROVAL_BUTTONS=false
# When true: for execute_gcloud_scale_up, show instruction only; hide gcloud command and Approve/Reject buttons
HIDE_GCLOUD_SCALE_UP_UI=false

GITHUB_TOKEN=ghp_...